.env
.env.*
*.local
*.log
*.tmp
*.temp
*.bak
*.swp

# Godot generated state
.godot/
.import/
export_presets.cfg

# Editor and OS state
.DS_Store
Thumbs.db
.vscode/
.idea/

# Common secret and certificate material
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_dsa
id_ecdsa
id_ed25519

# Local credential directories
.aws/
.ssh/
secrets/
credentials/

# Developer-local Godot integration sandboxes (see docs/INTEGRATION_TESTING.md)
integration-testing/*
!integration-testing/.gitkeep
!integration-testing/README.md

# Harness runtime output (see specs/009-evidence-lifecycle/)
# Transient zone — cleared between runs (use * so git can still traverse the dir for re-includes)
**/harness/automation/results/*
# Pinned zone — preserved deliberately; ignored by default, pin explicitly to share
**/harness/automation/pinned/
# Per-run evidence trees
**/evidence/automation/

# Re-include committed test oracles (*.expected.json) so the Pester suite still sees them
!**/harness/automation/results/*.expected.json