extends RefCounted
class_name KeyIdentifierResolver

# Maps the input-dispatch schema's key identifier names (uppercase
# `KEY_<name>` suffixes from Godot's global Key enum, with `DELETE` and the
# numeric digits matching the global constant suffix) to their integer
# keycode values, sourced directly from the global `KEY_*` constants so the
# values stay in sync with the engine without requiring runtime reflection.
#
# Background: `ClassDB.class_get_integer_constant("@GlobalScope", "KEY_*")`
# returns 0 in Godot 4.6 because the global Key enum is not registered as a
# ClassDB integer constant under `@GlobalScope`. Using literal references
# resolves the values at script-compile time, so no reflection is needed.

const KEYCODES: Dictionary = {
	"NONE": KEY_NONE,
	"SPECIAL": KEY_SPECIAL,
	"ESCAPE": KEY_ESCAPE,
	"TAB": KEY_TAB,
	"BACKTAB": KEY_BACKTAB,
	"BACKSPACE": KEY_BACKSPACE,
	"ENTER": KEY_ENTER,
	"KP_ENTER": KEY_KP_ENTER,
	"INSERT": KEY_INSERT,
	"DELETE": KEY_DELETE,
	"PAUSE": KEY_PAUSE,
	"PRINT": KEY_PRINT,
	"SYSREQ": KEY_SYSREQ,
	"CLEAR": KEY_CLEAR,
	"HOME": KEY_HOME,
	"END": KEY_END,
	"LEFT": KEY_LEFT,
	"UP": KEY_UP,
