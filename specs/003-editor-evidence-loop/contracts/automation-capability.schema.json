{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godot-agent-harness.local/specs/003-editor-evidence-loop/contracts/automation-capability.schema.json",
  "title": "Automation Capability Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "checkedAt",
    "projectIdentifier",
    "singleTargetReady",
    "launchControlAvailable",
    "runtimeBridgeAvailable",
    "captureControlAvailable",
    "persistenceAvailable",
    "validationAvailable",
    "shutdownControlAvailable",
    "blockedReasons",
    "recommendedControlPath"
  ],
  "properties": {
    "checkedAt": {
      "type": "string",
      "format": "date-time"
    },
    "projectIdentifier": {
      "type": "string",
      "minLength": 1
    },
    "singleTargetReady": {
      "type": "boolean"
    },
    "launchControlAvailable": {
      "type": "boolean"
    },
    "runtimeBridgeAvailable": {
      "type": "boolean"
    },
    "captureControlAvailable": {
      "type": "boolean"
    },
    "persistenceAvailable": {
      "type": "boolean"
    },
    "validationAvailable": {
      "type": "boolean"
    },
    "shutdownControlAvailable": {
      "type": "boolean"
    },
    "blockedReasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommendedControlPath": {
      "type": "string",
      "enum": ["file_broker", "editor_script_forwarder", "local_ipc"]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputDispatch": {
      "type": "object",
      "description": "Capability advertisement for the runtime input-dispatch feature (specs/006-input-dispatch).",
      "properties": {
        "supported": { "type": "boolean" },
        "maxEvents": { "type": "integer", "minimum": 0 },
        "supportedKinds": { "type": "array", "items": { "type": "string" } },
        "supportedPhases": { "type": "array", "items": { "type": "string" } },
        "laterSliceFields": { "type": "array", "items": { "type": "string" } },
        "blockedReasons": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string" }
      }
    },
    "runtimeErrorCapture": {
      "type": "object",
      "description": "Whether runtime-error and warning capture is available (specs/007-report-runtime-errors). v1 invariant: always supported when the addon is loaded.",
      "properties": {
        "supported": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    },
    "pauseOnError": {
      "type": "object",
      "description": "Whether the harness can pause the running playtest on runtime errors and wait for an agent decision (specs/007-report-runtime-errors). When unsupported the run executes in capture-only degraded mode.",
      "properties": {
        "supported": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    },
    "breakpointSuppression": {
      "type": "object",
      "description": "Whether user-set GDScript breakpoint statements are suppressed during agent runs (specs/007-report-runtime-errors). When unsupported, breakpoints are routed through the pause-decision flow with cause paused_at_user_breakpoint.",
      "properties": {
        "supported": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    }
  }
}
