{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godot-agent-harness.local/specs/006-input-dispatch/contracts/input-dispatch-script.schema.json",
  "title": "Input Dispatch Script",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "events"
  ],
  "properties": {
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/inputEvent"
      }
    }
  },
  "$defs": {
    "inputEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "identifier",
        "phase",
        "frame"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "key",
            "action"
          ]
        },
        "identifier": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "enum": [
            "press",
            "release"
          ]
        },
        "frame": {
          "type": "integer",
          "minimum": 0
        },
        "order": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
