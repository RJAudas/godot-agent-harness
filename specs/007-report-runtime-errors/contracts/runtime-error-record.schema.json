{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godot-agent-harness.local/specs/007-report-runtime-errors/contracts/runtime-error-record.schema.json",
  "title": "Runtime Error Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runId",
    "ordinal",
    "scriptPath",
    "line",
    "function",
    "message",
    "severity",
    "firstSeenAt",
    "lastSeenAt",
    "repeatCount"
  ],
  "properties": {
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "ordinal": {
      "type": "integer",
      "minimum": 0
    },
    "scriptPath": {
      "type": "string",
      "minLength": 1,
      "description": "Originating script res:// path, or the literal string 'unknown' when the engine could not resolve it."
    },
    "line": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "function": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "message": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["error", "warning"]
    },
    "firstSeenAt": {
      "type": "string",
      "format": "date-time"
    },
    "lastSeenAt": {
      "type": "string",
      "format": "date-time"
    },
    "repeatCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "truncatedAt": {
      "type": "integer",
      "const": 100,
      "description": "Present only when repeatCount reached the per-key cap and further occurrences were dropped."
    }
  }
}
