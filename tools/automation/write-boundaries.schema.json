{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://godot-agent-harness.local/tools/automation/write-boundaries.schema.json",
  "title": "Autonomous Write Boundaries",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "boundaries"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "minLength": 1
    },
    "boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "artifactId",
          "description",
          "allowedPaths",
          "allowedEditTypes",
          "stopConditions",
          "escalationConditions",
          "logOutputPath"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "artifactId": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "allowedPaths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "allowedEditTypes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["create", "update", "delete", "read-only"]
            }
          },
          "stopConditions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "escalationConditions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "logOutputPath": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}